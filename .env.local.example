# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Resend (email) — server-side only, ตั้งใน Cloudflare Pages env ด้วย
RESEND_API_KEY=re_...
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com

# Cloudflare Turnstile — bot protection บน quote form
# ใน dev เครื่อง: เว้นว่างได้ทั้งคู่ ระบบจะข้ามการตรวจ (ฟอร์ม/อีเมลยังทำงานปกติ)
# ใน production (Cloudflare Pages env): ต้องตั้งทั้งคู่เสมอ — ถ้าไม่ตั้ง
# TURNSTILE_SECRET_KEY ฝั่ง server จะข้ามการตรวจให้ ("fail open") ทำให้ endpoint
# /api/send-email (type=quote) ถูกยิงสแปมได้แบบไม่ต้อง auth/ไม่มี rate limit
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # required in production — Pages build env
TURNSTILE_SECRET_KEY=             # required in production — Pages Function secret

# Stripe (Phase 3 checkout) — server-side only, ตั้งใน Cloudflare Pages env ด้วย
# STRIPE_WEBHOOK_SECRET มาจาก Stripe Dashboard → Webhooks (endpoint /api/stripe-webhook)
# SUPABASE_SERVICE_ROLE_KEY ใช้โดย webhook สร้าง order — ห้ามใส่ตัวแปรที่ขึ้นต้น NEXT_PUBLIC
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Cloudflare Pages Deploy Hook
NEXT_PUBLIC_CF_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/...
